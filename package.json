{
  "name": "paymentsportal",
  "version": "1.0.0",
  "description": "Secure International Payments Portal - APDS7311",
  "main": "server/index.js",
  "scripts": {
  "start": "node server/index.js",
  "dev": "nodemon server/index.js",
  "client": "npm start --prefix client",
  "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
  "seed": "node server/seed.js",
  "test": "jest --coverage --forceExit",
  "test:ci": "jest --coverage --forceExit --ci"
},
"jest": {
  "testEnvironment": "node",
  "coverageDirectory": "coverage",
  "collectCoverageFrom": [
    "server/**/*.js",
    "!server/seed.js",
    "!server/config/**",
    "!server/index.js"
  ],
  "testMatch": [
    "**/tests/**/*.test.js"
  ]
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThembalethuNdlovu/PaymentsPortal.git"
  },
  "keywords": [],
  "author": "Thembalethu Ndlovu",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ThembalethuNdlovu/PaymentsPortal/issues"
  },
  "homepage": "https://github.com/ThembalethuNdlovu/PaymentsPortal#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-brute": "^1.0.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.3",
    "morgan": "^1.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
